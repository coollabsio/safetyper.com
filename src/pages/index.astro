---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Safetyper">
  <h1 class="text-3xl font-bold tracking-tight text-white md:text-6xl px-4">
    Keep your words safe & polished<span class="text-warning">.</span>
  </h1>
  <h2 class="text-base pt-2 text-neutral-400 px-4">
    A Grammarly alternative, where YOU own what you type on your keyboard.
  </h2>
  <div class="pb-6 pt-4 text-xs flex gap-2 justify-center flex-row flex-wrap">
    <a
      class="hover:underline cursor-pointer text-white flex gap-2 items-center justify-center text-xs"
      target="_blank"
      href="https://twitch.tv/heyandras"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="h-4 w-4 text-purple-500"
        width="200"
        height="200"
        viewBox="0 0 24 24"
        ><path
          fill="currentColor"
          d="M11.571 4.714h1.715v5.143H11.57zm4.715 0H18v5.143h-1.714zM6 0L1.714 4.286v15.428h5.143V24l4.286-4.286h3.428L22.286 12V0zm14.571 11.143l-3.428 3.428h-3.429l-3 3v-3H6.857V1.714h13.714Z"
        ></path></svg
      >

      Building in live-streams</a
    >
  </div>
  <div class="pb-2 pt-2 flex justify-center text-center gap-6 px-4 flex-wrap">
    <a
      href="https://chromewebstore.google.com/detail/safetyper/jfgghgeieficifndgplklafkhajffghg"
      target="_blank"
      class="text-base font-semibold text-white hover:text-warning flex gap-2 items-center"
    >
      <img src="/icons/chrome.svg" alt="Chrome" class="h-6 w-6" />
      Chrome</a
    >
    <a
      href="https://addons.mozilla.org/en-US/firefox/addon/safetyper/"
      target="_blank"
      class="text-base font-semibold text-white hover:text-warning flex gap-2 items-center"
    >
      <img src="/icons/firefox.svg" alt="Firefox" class="h-6 w-6" />
      Firefox</a
    >
  </div>
  <p class="text-sm text-neutral-400 text-center pt-2">Usage-based subscription coming soon.</p>

  <div id="features" class="text-center text-4xl font-bold pt-10 text-white">
    Features
  </div>
  <div
    class="mx-auto mt-16 max-w-2xl sm:mt-14 lg:mt-14 lg:max-w-none text-left"
  >
    <dl
      class="grid max-w-xl grid-cols-1 gap-x-8 px-4 gap-y-16 lg:max-w-none lg:grid-cols-2"
    >
      <div class="flex flex-col">
        <dt class="flex items-center gap-x-3 text-xl text-white">
          <svg
            class="icon text-warning"
            viewBox="0 0 24 24"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              fill="none"
              stroke="currentColor"
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="m7 8l-4 4l4 4m10-8l4 4l-4 4M14 4l-4 16"></path>
          </svg>
          Bring Your Own Key
        </dt>
        <dd
          class="mt-4 flex flex-auto flex-col text-sm leading-6 text-neutral-400"
        >
          <p class="flex-auto">
            Use your own OpenRouter or Groq API key. Your credentials stay
            on your device, never on our servers.
          </p>
        </dd>
      </div>
      <div class="flex flex-col">
        <dt class="flex items-center gap-x-3 text-xl text-white">
          <svg
            class="icon text-warning"
            viewBox="0 0 24 24"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              fill="none"
              stroke="currentColor"
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M3 7a3 3 0 0 1 3-3h12a3 3 0 0 1 3 3v2a3 3 0 0 1-3 3H6a3 3 0 0 1-3-3zm12 13H6a3 3 0 0 1-3-3v-2a3 3 0 0 1 3-3h12M7 8v.01M7 16v.01M20 15l-2 3h3l-2 3"
            ></path>
          </svg>
          Works Everywhere
        </dt>
        <dd
          class="mt-4 flex flex-auto flex-col text-sm leading-6 text-neutral-400"
        >
          <p class="flex-auto">
            Browser extension that works on any website — Gmail, Slack, Notion,
            social media, and more. Write better wherever you type.
          </p>
        </dd>
      </div>
      <div class="flex flex-col">
        <dt class="flex items-center gap-x-3 text-xl text-white">
          <svg
            class="icon text-warning"
            viewBox="0 0 24 24"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              fill="none"
              stroke="currentColor"
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M11 6h9m-9 6h9m-9 6h9M4 10V5.5a1.5 1.5 0 0 1 3 0V10M4 8h3M4 20h1.5a1.5 1.5 0 0 0 0-3H4h1.5a1.5 1.5 0 0 0 0-3H4z"
            ></path>
          </svg>
          Grammar & Spelling
        </dt>
        <dd
          class="mt-4 flex flex-auto flex-col text-sm leading-6 text-neutral-400"
        >
          <p class="flex-auto">
            Real-time grammar, spelling, and punctuation corrections powered by
            AI. Catch mistakes as you type, not after you hit send.
          </p>
        </dd>
      </div>
      <div class="flex flex-col">
        <dt class="flex items-center gap-x-3 text-xl text-white">
          <svg
            class="icon text-warning"
            viewBox="0 0 24 24"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              fill="none"
              stroke="currentColor"
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M12 18m-2 0a2 2 0 1 0 4 0a2 2 0 1 0-4 0M7 6m-2 0a2 2 0 1 0 4 0a2 2 0 1 0-4 0M17 6m-2 0a2 2 0 1 0 4 0a2 2 0 1 0-4 0M7 8v2a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2V8M12 12v4"
            ></path>
          </svg>
          Open Source
        </dt>
        <dd
          class="mt-4 flex flex-auto flex-col text-sm leading-6 text-neutral-400"
        >
          <p class="flex-auto">
            Fully open source. Read every line, verify our claims, and
            contribute. No black boxes, no hidden logic.
          </p>
          <p class="mt-6">
            <a
              href="https://github.com/coollabsio/safetyper"
              target="_blank"
              class="text-sm font-semibold leading-6 text-warning hover:underline"
              >View on GitHub <span aria-hidden="true">→</span></a
            >
          </p>
        </dd>
      </div>
    </dl>
  </div>
</Layout>
